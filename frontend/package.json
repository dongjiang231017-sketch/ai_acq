{
  "name": "ai-acq-qian-frontend",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "desktop": "electron electron/main.cjs",
    "desktop:preview": "AI_ACQ_FRONTEND_URL=http://127.0.0.1:4178 electron electron/main.cjs",
    "desktop:dev": "AI_ACQ_FRONTEND_URL=http://127.0.0.1:5173 electron electron/main.cjs",
    "desktop:runtime:prepare": "node scripts/prepare-asterisk-runtime.cjs --copy",
    "desktop:runtime:check": "node scripts/prepare-asterisk-runtime.cjs --check",
    "desktop:runtime:check:optional": "node scripts/prepare-asterisk-runtime.cjs --check --optional",
    "desktop:package": "npm run build && npm run desktop:runtime:check:optional && electron-builder --dir",
    "desktop:dist": "npm run build && npm run desktop:runtime:check:optional && electron-builder",
    "desktop:package:local-asterisk": "npm run build && npm run desktop:runtime:check && electron-builder --dir",
    "desktop:dist:local-asterisk": "npm run build && npm run desktop:runtime:check && electron-builder",
    "qa:v16": "node scripts/outbound-client-v16-qa.mjs",
    "qa:v15": "node scripts/v15-human-like-qa-explore.mjs",
    "quality:v16": "npm run build && npm run qa:v16 -- --json",
    "quality:v15": "npm run build && npm run qa:v15 -- --json",
    "quality:v16:desktop": "npm run build && npm run qa:v16 -- --desktop-app /Applications/商家AI获客客户端.app --json",
    "qa:v17": "node scripts/stateful-client-v17-qa.mjs",
    "quality:v17": "npm run build && npm run qa:v17 -- --json",
    "qa:v18": "node scripts/live-business-v18-qa.mjs",
    "qa:v18:plan": "node scripts/live-business-v18-qa.mjs --plan-only",
    "qa:v18:live": "node scripts/live-business-v18-qa.mjs --require-live",
    "qa:v18:batch-plan": "node scripts/live-business-v18-qa.mjs --plan-only --live-batch",
    "qa:v18:live-batch": "node scripts/live-business-v18-qa.mjs --require-live --live-batch",
    "quality:v18": "npm run build && npm run qa:v18:plan -- --json",
    "qa:v19": "node scripts/self-healing-v19-qa.mjs",
    "qa:v19:batch": "node scripts/self-healing-v19-qa.mjs --batch",
    "qa:v19:repair": "node scripts/self-healing-v19-qa.mjs --allow-repair",
    "quality:v19": "npm run build && npm run qa:v19 -- --repeat 2 --interval-ms 1000",
    "qa:v20": "node scripts/ui-locator-v20-qa.mjs",
    "qa:v20:batch": "node scripts/ui-locator-v20-qa.mjs --batch",
    "quality:v20": "npm run build && npm run qa:v20 -- --repeat 2 --interval-ms 1000",
    "qa:v21": "node scripts/evidence-evaluator-v21-qa.mjs",
    "qa:v21:batch": "node scripts/evidence-evaluator-v21-qa.mjs --batch",
    "quality:v21": "npm run build && npm run qa:v21 -- --repeat 2 --interval-ms 1000",
    "qa:v22": "node scripts/correlation-v22-qa.mjs",
    "qa:v22:batch": "node scripts/correlation-v22-qa.mjs --batch",
    "quality:v22": "npm run build && npm run qa:v22 -- --repeat 2 --interval-ms 1000",
    "qa:v23": "node scripts/correlation-v23-qa.mjs",
    "qa:v23:batch": "node scripts/correlation-v23-qa.mjs --batch",
    "quality:v23": "npm run build && npm run qa:v23 -- --repeat 2 --interval-ms 1000",
    "qa:v24": "node scripts/correlation-v24-qa.mjs",
    "qa:v24:batch": "node scripts/correlation-v24-qa.mjs --batch",
    "quality:v24": "npm run build && npm run qa:v24 -- --repeat 2 --interval-ms 1000",
    "qa:v25": "node scripts/ui-state-sync-v25-qa.mjs",
    "qa:v25:batch": "node scripts/ui-state-sync-v25-qa.mjs --batch",
    "quality:v25": "npm run build && npm run qa:v25 -- --repeat 2 --interval-ms 1000",
    "qa:v26": "node scripts/coverage-matrix-v26-qa.mjs",
    "qa:v26:batch": "node scripts/coverage-matrix-v26-qa.mjs --batch",
    "quality:v26": "npm run build && npm run qa:v26 -- --repeat 2 --interval-ms 1000",
    "qa:v27": "node scripts/collector-stateful-v27-qa.mjs",
    "qa:v27:batch": "node scripts/collector-stateful-v27-qa.mjs --batch",
    "quality:v27": "npm run build && npm run qa:v27 -- --repeat 2 --interval-ms 1000",
    "qa:v28": "node scripts/dm-stateful-v28-qa.mjs",
    "qa:v28:batch": "node scripts/dm-stateful-v28-qa.mjs --batch",
    "quality:v28": "npm run build && npm run qa:v28 -- --repeat 2 --interval-ms 1000",
    "qa:v29": "node scripts/comment-intent-v29-qa.mjs",
    "qa:v29:batch": "node scripts/comment-intent-v29-qa.mjs --batch",
    "quality:v29": "npm run build && npm run qa:v29 -- --repeat 2 --interval-ms 1000",
    "qa:v30": "node scripts/semantic-breadth-v30-qa.mjs",
    "qa:v30:batch": "node scripts/semantic-breadth-v30-qa.mjs --batch",
    "quality:v30": "npm run build && npm run qa:v30 -- --repeat 2 --interval-ms 1000",
    "qa:v31": "node scripts/openapi-model-v31-qa.mjs",
    "qa:v31:batch": "node scripts/openapi-model-v31-qa.mjs --batch",
    "quality:v31": "npm run build && npm run qa:v31 -- --repeat 2 --interval-ms 1000",
    "qa:v32": "node scripts/schemathesis-v32-qa.mjs",
    "qa:v32:batch": "node scripts/schemathesis-v32-qa.mjs --batch",
    "quality:v32": "npm run build && npm run qa:v32 -- --repeat 2 --interval-ms 1000",
    "qa:v33": "node scripts/live-acceptance-v33-qa.mjs",
    "qa:v33:plan": "node scripts/live-acceptance-v33-qa.mjs --plan-only",
    "qa:v33:live": "node scripts/live-acceptance-v33-qa.mjs --require-live",
    "qa:v33:live-batch": "node scripts/live-acceptance-v33-qa.mjs --require-live --live-batch",
    "quality:v33": "npm run build && npm run qa:v33:plan -- --json",
    "qa:v34": "node scripts/live-evidence-v34-qa.mjs",
    "qa:v34:plan": "node scripts/live-evidence-v34-qa.mjs --plan-only",
    "qa:v34:live": "node scripts/live-evidence-v34-qa.mjs --require-live",
    "qa:v34:live-batch": "node scripts/live-evidence-v34-qa.mjs --require-live --live-batch",
    "quality:v34": "npm run build && npm run qa:v34:plan -- --json",
    "qa:v35": "node scripts/live-blocker-director-v35-qa.mjs",

    "quality:v35": "npm run build && npm run qa:v35:plan -- --json",
    "qa:v36": "node scripts/live-allowlist-v36-qa.mjs",
    "qa:v36:validate": "node scripts/live-allowlist-v36-qa.mjs --allowlist qa/v36-real-live-allowlist.template.json",
    "qa:v36:strict": "node scripts/live-allowlist-v36-qa.mjs --strict",
    "qa:v36:template": "node scripts/live-allowlist-v36-qa.mjs",
    "quality:v36": "npm run build && npm run qa:v36:validate -- --json",
    "qa:v37": "node scripts/live-allowlist-schema-v37-qa.mjs",
    "qa:v37:validate": "node scripts/live-allowlist-schema-v37-qa.mjs --allowlist qa/v36-real-live-allowlist.template.json",
    "qa:v37:strict": "node scripts/live-allowlist-schema-v37-qa.mjs --strict",
    "quality:v37": "npm run build && npm run qa:v37:validate -- --json",
    "qa:v38": "node scripts/live-readiness-bundle-v38-qa.mjs",
    "qa:v38:strict": "node scripts/live-readiness-bundle-v38-qa.mjs --strict",
    "quality:v38": "npm run build && npm run qa:v38 -- --json --timeout-ms 30000",
    "qa:v39": "node scripts/live-readiness-trace-v39-qa.mjs",
    "qa:v39:strict": "node scripts/live-readiness-trace-v39-qa.mjs --strict",
    "quality:v39": "npm run build && npm run qa:v39 -- --json --skip-ui --timeout-ms 30000",
    "qa:v40": "node scripts/live-readiness-local-v40-qa.mjs",
    "qa:v40:strict": "node scripts/live-readiness-local-v40-qa.mjs --strict",
    "quality:v40": "npm run build && npm run qa:v40 -- --json --timeout-ms 30000",
    "qa:v41": "node scripts/auth-readiness-v41-qa.mjs",
    "qa:v41:strict": "node scripts/auth-readiness-v41-qa.mjs --strict",
    "quality:v41": "npm run build && npm run qa:v41 -- --json --timeout-ms 180000"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "ajv": "^8.20.0",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "com.aiacq.qian",
    "productName": "商家AI获客客户端",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/asterisk",
        "to": "asterisk",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}

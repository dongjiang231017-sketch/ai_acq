+    "给我发",
+)
+
+COMPLETE_QUESTION_MARKERS = (
+    "详细说一下",
+    "详细讲一下",
+    "具体说一下",
+    "介绍一下",
+    "说一下吗",
+    "讲一下吗",
+    "怎么做",
+    "怎么合作",
+    "流程",
+    "有什么优势",
+    "有什么用",

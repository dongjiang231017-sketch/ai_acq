APP_NAME=ai-acq-qian-api
API_PREFIX=/api
CORS_ORIGINS=["http://localhost:5173"]

# 本机 Homebrew PostgreSQL 默认用当前 macOS 用户连接，无需密码。
DATABASE_URL=postgresql+psycopg:///ai_acq_qian

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_SECRET_KEY=replace-this-with-a-long-random-string

# 实体电话卡 / UC100 默认先使用模拟网关。
# 客户交付版由桌面客户端内置/管理 Asterisk sidecar；不要依赖开发者本机。
# 客户端会在本机用户数据目录生成 backend-asterisk.env，正式安装包应让后端读取该文件。
TELEPHONY_GATEWAY_MODE=simulator
OUTBOUND_QUEUE_ENABLED=false
REDIS_URL=redis://localhost:6379/0
OUTBOUND_QUEUE_NAME=ai_acq:outbound_tasks
DM_QUEUE_ENABLED=false
DM_QUEUE_NAME=ai_acq:dm_tasks
DM_GATEWAY_MODE=simulator
DM_BROWSER_PROFILE_ROOT=.dm_browser_profiles
DM_BROWSER_HEADLESS=true
DM_BROWSER_CHANNEL=chrome
DM_BROWSER_TIMEOUT_MS=15000
DM_BROWSER_SLOW_MO_MS=0
DM_BROWSER_LIVE_SEND_ENABLED=false
COMMENT_INTERCEPT_LIVE_SYNC_ENABLED=false
COMMENT_INTERCEPT_ADAPTER_MODE=disabled

# DashScope / CosyVoice 声音复刻。不要提交真实 API Key。
VOICE_CLONE_TRAINING_ENABLED=false
VOICE_CLONE_PROVIDER=dashscope
VOICE_CLONE_ENGINE_NAME=DashScope CosyVoice
VOICE_SAMPLE_STORAGE_ROOT=.voice_samples
VOICE_OUTPUT_STORAGE_ROOT=.voice_outputs
# DashScope 创建音色需要可公网访问的音频 URL；本地调试可用 ngrok/cloudflared 指到 API 服务。
VOICE_SAMPLE_PUBLIC_BASE_URL=
DASHSCOPE_API_KEY=
DASHSCOPE_WORKSPACE=
DASHSCOPE_VOICE_CLONE_MODEL=cosyvoice-v2
DASHSCOPE_TTS_MODEL=cosyvoice-v2
DASHSCOPE_SYSTEM_TTS_MODEL=qwen3-tts-flash
DASHSCOPE_SYSTEM_TTS_LANGUAGE_TYPE=Chinese
DASHSCOPE_VOICE_PREFIX=aiacq
DASHSCOPE_VOICE_LANGUAGE_HINTS=zh
DASHSCOPE_PREVIEW_TEXT=您好，我是本地生活服务顾问，想和您确认一下是否方便了解视频号团购获客。
DASHSCOPE_SYSTEM_TTS_PREVIEW_TEXT=您好，我是本地生活服务顾问，想和您确认一下是否方便了解视频号团购获客。

# Asterisk/UC100 参数。客户交付版默认由桌面客户端 sidecar 生成，不要提交真实密码。
# 开发调试可临时复制客户端生成的 backend-asterisk.env 到本地 .env。
ASTERISK_HOST=127.0.0.1
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USERNAME=
ASTERISK_AMI_PASSWORD=
ASTERISK_AMI_TIMEOUT_SECONDS=5
ASTERISK_ORIGINATE_CONTEXT=from-ai-acq
ASTERISK_ORIGINATE_EXTENSION=s
ASTERISK_ORIGINATE_CHANNEL_TEMPLATE=PJSIP/{phone}@{trunk}
ASTERISK_ORIGINATE_TIMEOUT_MS=30000
ASTERISK_CALLER_ID=AI获客
ASTERISK_TRUNK_NAME=uc100
ASTERISK_MAX_CHANNELS=1
# 单号试拨开关。确认 UC100/Asterisk 线路联通后再改 true。
ASTERISK_LIVE_CALL_ENABLED=false
# 批量任务真实拨号开关。必须在单号试拨稳定后再改 true。
ASTERISK_BULK_CALL_ENABLED=false

APP_NAME=ai-acq-qian-api
API_PREFIX=/api
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# 本机 Homebrew PostgreSQL 默认用当前 macOS 用户连接，无需密码。
DATABASE_URL=postgresql+psycopg:///ai_acq_qian

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_SECRET_KEY=replace-this-with-a-long-random-string
AUTH_SECRET_KEY=replace-this-with-a-long-random-auth-string
ACCESS_TOKEN_EXPIRE_SECONDS=604800

# 可选兜底配置。推荐在 SQLAdmin「采集接口配置」里填写高德/百度/腾讯接口密钥。
# 高德申请地址：https://console.amap.com/dev/key/app
AMAP_WEB_KEY=
COLLECTION_REQUEST_TIMEOUT_SECONDS=8

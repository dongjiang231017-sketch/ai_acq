# ===== LiveKit（与 deploy/livekit.yaml keys 一致）=====
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=REPLACE_WITH_RANDOM_SECRET

# ===== 外呼 trunk（scripts/create_trunk.sh 输出的 ST_xxx）=====
SIP_OUTBOUND_TRUNK_ID=ST_xxxxxxxx

# ===== Qwen Omni Realtime（阿里云百炼）=====
DASHSCOPE_API_KEY=sk-REPLACE
QWEN_REALTIME_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
QWEN_REALTIME_MODEL=qwen3-omni-flash-realtime
QWEN_VOICE=Cherry

# ===== 通话行为 =====
# 商家名等业务上下文由 dial 接口按通传入，这里是默认值
MERCHANT_NAME_DEFAULT=您的门店
# 服务端 VAD 静音判停毫秒数（PoC 调参重点：300-500 之间试）
VAD_SILENCE_MS=400
# 垫词开关（assets/ 下需有 filler_*.wav，可用 scripts/gen_fillers.py 生成）
ENABLE_FILLER=true

# ===== 延迟打点输出目录 =====
METRICS_DIR=./metrics_logs
